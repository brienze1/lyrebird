{
  "id": "gcp-kms",
  "title": "GCP Cloud KMS encrypt (REST API, path-routed)",
  "provider": "gcp",
  "service": "kms",
  "description": "Cloud KMS's encrypt operation POSTs to /v1/{keyName}:encrypt. Point the client library at Lyrebird via its endpoint-override option with a plain-HTTP transport.",
  "mock": {
    "name": "gcp-kms-encrypt",
    "match": { "method": "POST", "path": "/v1/projects/example-project/locations/global/keyRings/example-ring/cryptoKeys/example-key:encrypt" },
    "action": {
      "respond": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "body": "{\"name\":\"projects/example-project/locations/global/keyRings/example-ring/cryptoKeys/example-key\",\"ciphertext\":\"ZXhhbXBsZS1jaXBoZXJ0ZXh0\"}"
      }
    }
  }
}
